#!/usr/bin/env bun
/**
 * Pre-commit hook script.
 *
 * Responsibilities:
 *  1. Syntax & AST check  — biome check on all staged TS/JS files
 *  2. Type check          — tsgo on all staged TS/JS files
 *  3. Test & coverage     — for newly touched logic files:
 *       • Run the relevant test files
 *       • Enforce ≥ 50 % line coverage on those logic files
 *  4. Overall coverage gate — ensure the whole repo stays ≥ 70 %
 */

"use strict";

import { existsSync } from "node:fs";
import { readFileSync } from "node:fs";
import { readdirSync } from "node:fs";
import { statSync } from "node:fs";
import { execFileSync } from "node:child_process";
import { spawnSync } from "node:child_process";
import { join, relative, extname, basename, dirname } from "node:path";
import { cwd } from "node:process";

// ─── Helpers ────────────────────────────────────────────────────────────────

function run(cmd, args, opts = {}) {
	return spawnSync(cmd, args, {
		stdio: "inherit",
		cwd: opts.cwd ?? cwd(),
		...opts,
	});
}

function readJson(path) {
	try {
		return JSON.parse(readFileSync(path, "utf8"));
	} catch {
		return null;
	}
}

const ROOT = cwd();

/** Absolute paths of all staged files that look like source files. */
function getStagedFiles() {
	const out = execFileSync("git", ["diff", "--cached", "--name-only", "-z"], {
		encoding: "utf8",
		cwd: ROOT,
	});
	if (!out.trim()) return [];
	return out.split("\0").filter(Boolean);
}

/**
 * Find test files that correspond to a given source file.
 * Convention: `<dir>/foo.ts` → `<dir>/test/foo.test.ts` (or `.spec.ts`)
 */
function findTestFiles(srcFile) {
	const dir = dirname(srcFile);
	const base = basename(srcFile, ".ts");
	const candidates = [
		join(dir, "test", `${base}.test.ts`),
		join(dir, "test", `${base}.spec.ts`),
		join(dir, `../test/${base}.test.ts`),
		join(dir, `../test/${base}.spec.ts`),
	];
	return candidates.filter((p) => existsSync(p));
}

/**
 * Find all test files that exercise a source file (or its parent directory).
 * Uses the test directory layout of this repo.
 */
function resolveTestFiles(stagedSrcFiles) {
	const seen = new Set();
	const tests = [];

	for (const src of stagedSrcFiles) {
		// If already a test file, include it directly
		if (src.includes("/test/") && (src.endsWith(".test.ts") || src.endsWith(".spec.ts"))) {
			if (!seen.has(src)) {
				seen.add(src);
				tests.push(src);
			}
		} else {
			// Find companion test files
			const found = findTestFiles(src);
			for (const t of found) {
				if (!seen.has(t)) {
					seen.add(t);
					tests.push(t);
				}
			}
		}
	}

	return tests;
}

/** Convert absolute path to package-relative path used in coverage config. */
function toCoveragePattern(absPath) {
	return absPath.replace(ROOT + "/", "./");
}

// ─── Step 1 — Syntax / AST check with Biome ──────────────────────────────────

function runBiomeCheck(stagedFiles) {
	if (stagedFiles.length === 0) return true;

	const tsfiles = stagedFiles.filter((f) =>
		/\.(ts|tsx|js|jsx|json|jsonc)$/.test(f),
	);
	if (tsfiles.length === 0) return true;

	console.log("\n🪥  Running Biome syntax / AST check…");
	const result = spawnSync("bun", ["run", "lint:ts", "--", "--error-on-warnings", ...tsfiles], {
		cwd: ROOT,
	});
	if (result.status !== 0) {
		console.error("\n❌  Biome check failed. Please fix the errors above.");
		return false;
	}
	console.log("✅  Biome check passed.");
	return true;
}

// ─── Step 2 — Type check with tsgo ──────────────────────────────────────────

function runTypeCheck(stagedFiles) {
	if (stagedFiles.length === 0) return true;

	const tsfiles = stagedFiles.filter((f) => /\.(ts|tsx)$/.test(f));
	if (tsfiles.length === 0) return true;

	console.log("\n🔍  Running TypeScript type check…");
	// Run tsgo on the workspace to catch all type errors in affected packages
	const result = spawnSync("bun", ["run", "check:ts"], {
		cwd: ROOT,
	});
	if (result.status !== 0) {
		console.error("\n❌  TypeScript type check failed.");
		return false;
	}
	console.log("✅  TypeScript type check passed.");
	return true;
}

// ─── Step 3 — Test + 50 % coverage gate for new/changed logic files ──────────

function runTestsForChangedFiles(stagedSrcFiles) {
	const testFiles = resolveTestFiles(stagedSrcFiles);

	if (testFiles.length === 0) {
		console.log("\n📋  No corresponding test files found for staged source changes.");
		console.log("   (If you added new logic, please add a test file.)");
		return true;
	}

	const uniqueSrcFiles = [...new Set(stagedSrcFiles.filter(
		(f) => !f.includes("/test/") && !f.endsWith(".d.ts"),
	))];
	const coveragePatterns = uniqueSrcFiles.map(toCoveragePattern);

	console.log(`\n🧪  Running tests for ${testFiles.length} test file(s)…`);
	console.log("   Source files covered:", uniqueSrcFiles.join(", "));

	// Build --test-name-pattern that exercises only the specific files.
	// We run tests normally; coverage is filtered below.
	const args = [
		"test",
		"--coverage",
		"--coverage-reporter=text",
		"--coverage-reporter=lcov",
		"--coverage-dir=coverage",
		...testFiles,
	];

	const result = spawnSync("bun", args, { cwd: ROOT });

	if (result.status !== 0) {
		console.error("\n❌  Tests failed.");
		return false;
	}

	// Read coverage report and enforce ≥ 50 % per-file for touched logic files
	const lcovPath = join(ROOT, "coverage", "lcov.info");
	if (existsSync(lcovPath)) {
		const lcov = readFileSync(lcovPath, "utf8");
		const lines = lcov.split("\n");
		let currentFile = null;
		let lineFound = 0, lineHit = 0;
		const fileStats = {};

		for (const line of lines) {
			if (line.startsWith("SF:")) {
				// finalize previous
				if (currentFile) {
					const key = toCoveragePattern(currentFile);
					fileStats[key] = { found: lineFound, hit: lineHit };
				}
				currentFile = line.slice(3);
				lineFound = 0;
				lineHit = 0;
			} else if (line.startsWith("DA:")) {
				const [, found, hit] = line.split(":");
				if (found !== undefined) {
					lineFound++;
					if (parseInt(hit) > 0) lineHit++;
				}
			}
		}
		if (currentFile) {
			const key = toCoveragePattern(currentFile);
			fileStats[key] = { found: lineFound, hit: lineHit };
		}

		let allPass = true;
		for (const pattern of coveragePatterns) {
			// Try exact match, then glob-style prefix match
			const matchKey = Object.keys(fileStats).find(
				(k) => k === pattern || k.endsWith(pattern) || pattern.endsWith(k),
			);
			if (matchKey) {
				const { found, hit } = fileStats[matchKey];
				const pct = found > 0 ? Math.round((hit / found) * 100) : 0;
				if (pct < 50) {
					console.error(
						`\n❌  Coverage for ${pattern} is ${pct}% (need ≥ 50%).`,
						`   Found: ${found} lines, Hit: ${hit} lines`,
					);
					allPass = false;
				} else {
					console.log(`   ✅  ${pattern}: ${pct}% coverage (${hit}/${found} lines)`);
				}
			} else {
				// No coverage data for this file — warn but don't fail unless it looks like logic
				if (!pattern.endsWith(".d.ts")) {
					console.warn(`   ⚠️  No coverage data for ${pattern} — consider adding tests`);
				}
			}
		}

		if (!allPass) {
			console.error("\n❌  Coverage gate failed: some files below 50%.");
			return false;
		}
	}

	console.log("✅  Tests passed with ≥ 50% coverage on changed logic files.");
	return true;
}

// ─── Step 4 — Overall 70 % coverage check (on full test run) ─────────────────

function checkOverallCoverage() {
	const lcovPath = join(ROOT, "coverage", "lcov.info");
	if (!existsSync(lcovPath)) {
		console.log("\n⚠️  No coverage report found — skipping overall coverage check.");
		return true;
	}

	const lcov = readFileSync(lcovPath, "utf8");
	const lines = lcov.split("\n");
	let totalFound = 0, totalHit = 0;
	let currentFile = null;
	let fileFound = 0, fileHit = 0;

	for (const line of lines) {
		if (line.startsWith("SF:")) {
			if (currentFile) {
				totalFound += fileFound;
				totalHit += fileHit;
			}
			currentFile = line.slice(3);
			fileFound = 0;
			fileHit = 0;
		} else if (line.startsWith("DA:")) {
			const parts = line.split(":");
			if (parts.length >= 2) {
				fileFound++;
				if (parseInt(parts[1]) > 0) fileHit++;
			}
		}
	}
	if (currentFile) {
		totalFound += fileFound;
		totalHit += fileHit;
	}

	if (totalFound === 0) {
		console.log("\n⚠️  No coverable lines found in coverage report.");
		return true;
	}

	const overall = Math.round((totalHit / totalFound) * 100);
	console.log(`\n📊  Overall coverage: ${overall}% (${totalHit}/${totalFound} lines)`);

	if (overall < 70) {
		console.error(`\n❌  Overall coverage is ${overall}%, need ≥ 70%.`);
		return false;
	}

	console.log("✅  Overall coverage ≥ 70%.");
	return true;
}

// ─── Main ─────────────────────────────────────────────────────────────────────

function main() {
	console.log("🔔  Pre-commit hook starting…");

	const stagedFiles = getStagedFiles();
	if (stagedFiles.length === 0) {
		console.log("Nothing staged — skipping pre-commit checks.");
		return;
	}

	const tsfiles = stagedFiles.filter((f) => /\.ts$/i.test(f));

	// 1. Biome syntax/AST check
	if (!runBiomeCheck(stagedFiles)) process.exit(1);

	// 2. TypeScript type check
	if (!runTypeCheck(tsfiles)) process.exit(1);

	// 3. Tests + 50% coverage gate for newly changed logic files
	// Only run if there are non-test, non-declaration source files staged
	const logicFiles = tsfiles.filter(
		(f) => !f.includes("/test/") && !f.endsWith(".d.ts"),
	);
	if (logicFiles.length > 0) {
		if (!runTestsForChangedFiles(logicFiles)) process.exit(1);
	} else {
		console.log("\n📋  No logic source files staged — skipping test/coverage gate.");
	}

	// 4. Overall 70% coverage (only on CI — disable locally to avoid blocking on
	//   edge-case files that aren't exercised by the targeted test suite)
	const enforceOverall = process.env.ENFORCE_OVERALL_COVERAGE === "1";
	if (enforceOverall) {
		if (!checkOverallCoverage()) process.exit(1);
	} else {
		console.log(
			"\nℹ️  Set ENFORCE_OVERALL_COVERAGE=1 to enforce the 70% overall coverage gate.",
		);
	}

	console.log("\n🎉  Pre-commit checks passed!");
}

main();
